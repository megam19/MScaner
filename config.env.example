# Пример конфигурации MScaner. Скопируйте в config.env рядом с mscaner.exe
# и отредактируйте под свою систему.

# Путь к сканируемой папке.
# Windows (сетевая шара): DIR_PATH=\\air-02\imagine_mxf
# Windows (локальная):    DIR_PATH=D:\video\mxf
# Linux/Docker:           DIR_PATH=/scan
DIR_PATH=\\air-02\imagine_mxf

# Расширение отслеживаемых файлов (с точкой, регистр не важен).
FILE_EXTENSION=.mxf

# Путь к файлу SQLite. Директория создастся автоматически.
DATABASE_PATH=./database/sqlite3DB.db

# Интервал сканирования, секунд.
SCAN_INTERVAL_SEC=120

# Интервал очистки старых записей, часов.
PURGE_INTERVAL_HOURS=24

# Возраст «забытой» записи для физического удаления, дней.
RETENTION_DAYS=10

# Адрес веб-интерфейса. ":8080" — слушать все интерфейсы на порту 8080.
# "127.0.0.1:8080" — только localhost.
HTTP_ADDR=:8080

# Окно, в течение которого свежий файл подсвечивается в UI как «новый», секунд.
HIGHLIGHT_WINDOW_SEC=3600
